    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-argon2": "^4.0.0",
    "react-native-mmkv": "3.3.3",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
