{
  "name": "smartcard",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "adb reverse tcp:8081 tcp:8081 && expo start --dev-client --host localhost",
    "android": "adb reverse tcp:8081 tcp:8081 && set REACT_NATIVE_PACKAGER_HOSTNAME=localhost&& expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.js --max-warnings=0",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
