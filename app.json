{
  "expo": {
    "name": "SmartCard",
    "slug": "smartcard",
    "scheme": "smartcard",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smartcard.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.smartcard.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "לאפשר ל-SmartCard לסרוק קוד QR לשיתוף פרופיל"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ]
  }
}
